:root {
  --background: #ffffff;
  --foreground: #171717;
  font-size: 16px;
}
@media (min-width: 640px) {
  :root {
    font-size: 16.5px;
  }
}
@media (min-width: 1024px) {
  :root {
    font-size: 17px;
  }
}
@media (prefers-color-scheme: dark) {
  :root {
    --background: #000000;
    --foreground: #ededed;
  }
}
.dark {
  --background: #000000;
  --foreground: #ededed;
}
body {
  background-color: var(--background);
  color: var(--foreground);
  transition: background-color 0.3s ease, color 0.3s ease;
  font-family: var(--font-philosopher), sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  line-height: 1.6;
}
::-webkit-scrollbar {
  display: none;
}
* {
  -ms-overflow-style: none;
  scrollbar-width: none;
}
@keyframes infinite-scroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}
@keyframes infinite-scroll-reverse {
  from {
    transform: translateX(-50%);
  }
  to {
    transform: translateX(0);
  }
}
.animate-infinite-scroll {
  animation: infinite-scroll 60s linear infinite;
  will-change: transform;
}
.animate-infinite-scroll-reverse {
  animation: infinite-scroll-reverse 60s linear infinite;
  will-change: transform;
}
.animate-infinite-scroll-slow {
  animation: infinite-scroll 80s linear infinite;
  will-change: transform;
}
.pause-on-hover:hover .animate-infinite-scroll,
.pause-on-hover:hover .animate-infinite-scroll-slow {
  animation-play-state: paused;
}
